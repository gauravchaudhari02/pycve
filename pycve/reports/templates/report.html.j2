<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>PyCVE Security Report</title>
  <style>
    :root {
      --critical: #dc3545; --high: #fd7e14; --medium: #ffc107;
      --low: #198754; --unknown: #6c757d;
      --bg: #0f1117; --card: #1a1d26; --border: #2d3148;
      --text: #e2e8f0; --subtext: #94a3b8;
      --accent: #6366f1;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); padding: 2rem; }
    h1 { font-size: 1.8rem; color: var(--accent); margin-bottom: 0.25rem; }
    .meta { color: var(--subtext); font-size: 0.85rem; margin-bottom: 2rem; }

    /* Summary cards */
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px,1fr)); gap: 1rem; margin-bottom: 2rem; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1rem; text-align: center; }
    .card .num { font-size: 2rem; font-weight: 700; }
    .card .lbl { font-size: 0.75rem; color: var(--subtext); margin-top: 0.25rem; }
    .card.critical .num { color: var(--critical); }
    .card.high     .num { color: var(--high); }
    .card.medium   .num { color: var(--medium); }
    .card.low      .num { color: var(--low); }

    /* Table */
    .tbl-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    thead { background: var(--card); }
    th { padding: 0.75rem 1rem; text-align: left; color: var(--subtext); font-weight: 600; white-space: nowrap; }
    td { padding: 0.65rem 1rem; border-top: 1px solid var(--border); vertical-align: top; }
    tr:hover td { background: rgba(99,102,241,0.05); }

    /* Severity badges */
    .badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
    .CRITICAL { background: rgba(220,53,69,0.2); color: var(--critical); }
    .HIGH     { background: rgba(253,126,20,0.2); color: var(--high); }
    .MEDIUM   { background: rgba(255,193,7,0.2);  color: var(--medium); }
    .LOW      { background: rgba(25,135,84,0.2);  color: var(--low); }
    .UNKNOWN  { background: rgba(108,117,125,0.2); color: var(--unknown); }

    /* CVE ID link */
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .desc { max-width: 500px; color: var(--subtext); font-size: 0.8rem; }

    footer { margin-top: 2rem; text-align: center; color: var(--subtext); font-size: 0.8rem; }
  </style>
</head>
<body>
  <h1>🛡 PyCVE Security Report</h1>
  <p class="meta">Generated: {{ generated_at }} &nbsp;|&nbsp; Total CVEs: {{ cves | length }}</p>

  <!-- Summary cards -->
  <div class="cards">
    <div class="card" style="border-color:var(--accent)">
      <div class="num">{{ cves | length }}</div>
      <div class="lbl">Total CVEs</div>
    </div>
    {% for sev in ['CRITICAL','HIGH','MEDIUM','LOW'] %}
    <div class="card {{ sev | lower }}">
      <div class="num">{{ severity_counts.get(sev, 0) }}</div>
      <div class="lbl">{{ sev }}</div>
    </div>
    {% endfor %}
    <div class="card">
      <div class="num" style="color:var(--low)">{{ patched_count }}</div>
      <div class="lbl">Patched</div>
    </div>
    <div class="card">
      <div class="num" style="color:var(--critical)">{{ unpatched_count }}</div>
      <div class="lbl">Unpatched</div>
    </div>
  </div>

  <!-- CVE table -->
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>CVE ID</th>
          <th>Severity</th>
          <th>CVSS</th>
          <th>Published</th>
          <th>Status</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {% for cve in cves %}
        <tr>
          <td>
            <a href="https://nvd.nist.gov/vuln/detail/{{ cve.id }}" target="_blank">{{ cve.id }}</a>
          </td>
          <td><span class="badge {{ cve.severity }}">{{ cve.severity }}</span></td>
          <td>{{ cve.cvss_score if cve.cvss_score is not none else '—' }}</td>
          <td>{{ cve.published.strftime('%Y-%m-%d') if cve.published else '—' }}</td>
          <td>{{ cve.vuln_status }}</td>
          <td class="desc">{{ cve.description }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <footer>Generated by <strong>PyCVE</strong> &nbsp;|&nbsp; Data source: NIST NVD API v2</footer>
</body>
</html>
